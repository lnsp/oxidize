# oxidize service configuration. Copy to /etc/oxidize/oxidize.env on the VM
# (chmod 600) and fill in. The Proxmox API token goes in /etc/oxidize/TOKEN.
OXIDIZE_LISTEN=:8080
PROXMOX_HOST=https://192.168.1.50:8006
PROXMOX_TOKEN_FILE=/etc/oxidize/TOKEN
PROXMOX_INSECURE=true
OXIDIZE_DATA_DIR=/var/lib/oxidize
OXIDIZE_USER=admin
OXIDIZE_PASS=change-me
OXIDIZE_SESSION_SECRET=change-me-to-a-long-random-string
